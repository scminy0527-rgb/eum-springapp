<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.springapp.mapper.EduVideoMapper">

    <!-- 수어 영상 상세 조회 -->
    <select id="select" parameterType="Long" resultType="EduVideoResponseDTO">
        SELECT ID, EDU_VIDEO_TITLE, EDU_VIDEO_DETAIL, EDU_VIDEO_TYPE, EDU_VIDEO_URL, EDU_VIDEO_CREATE_AT
        FROM TBL_EDU_VIDEO
        WHERE ID = #{id}
    </select>

</mapper>